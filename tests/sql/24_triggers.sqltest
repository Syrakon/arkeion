-- Triggers row-level: {BEFORE|AFTER} {INSERT|UPDATE|DELETE}, cuerpo DML con
-- OLD/NEW sustituidos por los valores de la fila. Guarda de recursión.

> CREATE TABLE accounts (id INTEGER PRIMARY KEY, name TEXT, balance INTEGER);
ok

> CREATE TABLE audit (id INTEGER PRIMARY KEY, msg TEXT);
ok

-- Audit-log: un trigger por evento, usando NEW/OLD.
> CREATE TRIGGER log_ins AFTER INSERT ON accounts BEGIN INSERT INTO audit (msg) VALUES ('ins:' || CAST(NEW.id AS TEXT)); END;
ok

> CREATE TRIGGER log_upd AFTER UPDATE ON accounts BEGIN INSERT INTO audit (msg) VALUES ('upd:' || CAST(OLD.balance AS TEXT) || '->' || CAST(NEW.balance AS TEXT)); END;
ok

> CREATE TRIGGER log_del AFTER DELETE ON accounts BEGIN INSERT INTO audit (msg) VALUES ('del:' || OLD.name); END;
ok

> INSERT INTO accounts (name, balance) VALUES ('ada', 100);
affected 1

> UPDATE accounts SET balance = 150 WHERE id = 1;
affected 1

> DELETE FROM accounts WHERE id = 1;
affected 1

-- El audit refleja los tres eventos (NEW.id, OLD/NEW.balance, OLD.name).
> SELECT msg FROM audit ORDER BY id;
ins:1
upd:100->150
del:ada

-- BEFORE INSERT que escribe en otra tabla (NEW visible).
> CREATE TABLE inbox (id INTEGER PRIMARY KEY, txt TEXT);
ok

> CREATE TABLE sent (id INTEGER PRIMARY KEY, txt TEXT);
ok

> CREATE TRIGGER fwd BEFORE INSERT ON inbox BEGIN INSERT INTO sent (txt) VALUES (NEW.txt); END;
ok

> INSERT INTO inbox (txt) VALUES ('hi');
affected 1

> SELECT txt FROM sent;
hi

-- Recursión: un trigger que escribe en su propia tabla se acota.
> CREATE TABLE loop_t (id INTEGER PRIMARY KEY, n INTEGER);
ok

> CREATE TRIGGER loopy AFTER INSERT ON loop_t BEGIN INSERT INTO loop_t (n) VALUES (NEW.n + 1); END;
ok

> INSERT INTO loop_t (n) VALUES (0);
error recursión

-- DROP TRIGGER.
> DROP TRIGGER log_ins;
ok

> DROP TRIGGER IF EXISTS nope;
ok

-- OLD no está disponible en un trigger de INSERT (error al disparar).
> CREATE TRIGGER bad AFTER INSERT ON accounts BEGIN INSERT INTO audit (msg) VALUES (OLD.name); END;
ok

> INSERT INTO accounts (name, balance) VALUES ('zoe', 5);
error OLD no está disponible

-- Errores de creación.
> CREATE TRIGGER t2 AFTER INSERT ON ghosttable BEGIN DELETE FROM audit; END;
error tabla del trigger no existe

> CREATE TRIGGER log_upd AFTER UPDATE ON accounts BEGIN DELETE FROM audit; END;
error el trigger ya existe
