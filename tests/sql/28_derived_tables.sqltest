-- Tablas derivadas: `FROM (SELECT …) AS alias` (subconsulta en el FROM/JOIN). Se
-- materializan como una CTE anónima; el alias es obligatorio y es el qualifier.

> CREATE TABLE sales (id INTEGER PRIMARY KEY, region TEXT, amount INTEGER);
ok

> INSERT INTO sales (region, amount) VALUES ('n', 10), ('n', 20), ('s', 30), ('s', 5);
affected 4

-- Derivada simple.
> SELECT amount FROM (SELECT amount FROM sales WHERE amount >= 20) AS big ORDER BY amount;
20
30

-- Derivada con agregado, consultada por fuera.
> SELECT region, total FROM (SELECT region, sum(amount) AS total FROM sales GROUP BY region) AS t ORDER BY region;
n|30
s|35

-- Columnas calificadas por el alias.
> SELECT t.region FROM (SELECT region FROM sales) AS t WHERE t.region = 's' ORDER BY t.region;
s
s

-- Derivada en un JOIN con una tabla real.
> SELECT s.region, hi.amount FROM sales s INNER JOIN (SELECT id, amount FROM sales WHERE amount >= 20) AS hi ON s.id = hi.id ORDER BY hi.amount;
n|20
s|30

-- Dos derivadas (no se ven entre sí: sin LATERAL).
> SELECT a.region, b.amount FROM (SELECT region FROM sales WHERE id = 1) AS a INNER JOIN (SELECT amount FROM sales WHERE id = 3) AS b ON 1 = 1;
n|30

-- Derivada anidada (una envuelve a otra).
> SELECT m FROM (SELECT max(amount) AS m FROM (SELECT amount FROM sales WHERE region = 'n') AS inner_t) AS outer_t;
20

-- Una derivada necesita alias.
> SELECT amount FROM (SELECT amount FROM sales);
error alias
