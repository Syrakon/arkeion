-- CTEs recursivas: WITH RECURSIVE t AS (semilla UNION [ALL] término) … — punto
-- fijo, el término ve la CTE = las filas del paso anterior. Guarda contra recursión
-- sin caso base.

-- Contador 1..5 (UNION ALL, sin dedup; termina por el WHERE).
> WITH RECURSIVE nums AS (SELECT 1 AS n UNION ALL SELECT n + 1 FROM nums WHERE n < 5) SELECT n FROM nums ORDER BY n;
1
2
3
4
5

-- Cierre transitivo: descendientes de 1 en un árbol.
> CREATE TABLE edges (parent INTEGER, child INTEGER);
ok

> INSERT INTO edges (parent, child) VALUES (1, 2), (1, 3), (2, 4), (3, 5), (4, 6);
affected 5

> WITH RECURSIVE reach AS (SELECT child FROM edges WHERE parent = 1 UNION SELECT e.child FROM edges e INNER JOIN reach d ON e.parent = d.child) SELECT child FROM reach ORDER BY child;
2
3
4
5
6

-- UNION (no ALL) deduplica: un grafo con varios caminos no repite nodos.
> INSERT INTO edges (parent, child) VALUES (2, 5);
affected 1

> WITH RECURSIVE reach AS (SELECT child FROM edges WHERE parent = 1 UNION SELECT e.child FROM edges e INNER JOIN reach d ON e.parent = d.child) SELECT child FROM reach ORDER BY child;
2
3
4
5
6

-- Recursión sin caso base: se acota (crece exponencialmente y supera el tope).
> CREATE TABLE two (x INTEGER);
ok

> INSERT INTO two (x) VALUES (1), (2);
affected 2

> WITH RECURSIVE inf AS (SELECT 1 AS n UNION ALL SELECT inf.n FROM inf INNER JOIN two ON 1 = 1) SELECT n FROM inf;
error demasiadas filas

-- Forma no soportada: más de un término de conjunto.
> WITH RECURSIVE bad AS (SELECT 1 AS n UNION SELECT 2 UNION SELECT n FROM bad) SELECT n FROM bad;
error semilla UNION
